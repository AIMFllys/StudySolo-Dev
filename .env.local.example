# Environment Variables for MCP Integrations
# Copy this file to .env.local and fill in your actual tokens

# ===== Supabase Configuration =====
# Get SUPABASE_ACCESS_TOKEN from: https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=

# Your Supabase project ID (visible in project URL: https://app.supabase.com/project/[PROJECT_ID])
SUPABASE_PROJECT_ID=

# ===== GitHub Configuration =====
# Get GITHUB_TOKEN from: https://github.com/settings/tokens
# Recommended scopes: repo, gist, read:user, workflow
GITHUB_TOKEN=

# ===== Optional: Upstash Configuration =====
# Get UPSTASH_API_KEY from: https://console.upstash.com/
UPSTASH_API_KEY=
