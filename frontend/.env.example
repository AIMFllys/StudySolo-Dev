# ============================================
# StudySolo Frontend - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in real values
# cp .env.example .env.local
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API base URL
# Server-side / Next.js rewrites 优先使用 INTERNAL_API_BASE_URL
INTERNAL_API_BASE_URL=http://127.0.0.1:2038

# Legacy public fallback（仅为兼容旧代码保留）
NEXT_PUBLIC_API_BASE_URL=http://localhost:2038

# Legacy fallback (deprecated, will be removed)
# NEXT_PUBLIC_APP_URL=http://localhost:2038

# SSO Cookie Domain (production only, leave empty for local dev)
# NEXT_PUBLIC_COOKIE_DOMAIN=.1037solo.com
