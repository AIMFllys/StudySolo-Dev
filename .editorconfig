root = true

[*.{js,jsx,ts,tsx,mjs,cjs,json,md,mdx,yml,yaml,toml,ini,css,scss,less,html,xml,py,sh,ps1}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf
