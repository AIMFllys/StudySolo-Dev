# Required: set a real shared secret before starting the agent.
# Local requests must send: Authorization: Bearer <AGENT_API_KEY>
AGENT_NAME=study-tutor
AGENT_VERSION=0.1.0
AGENT_MODEL_ID=study-tutor-v1
AGENT_API_KEY=replace-with-a-strong-secret

# Local bind address / port for the FastAPI process.
AGENT_HOST=127.0.0.1
AGENT_PORT=8004

# Use "*" only for local development. In production, restrict to Gateway or frontend origins.
AGENT_CORS_ALLOW_ORIGINS=*

# In-memory single-process rate limit.
AGENT_RATE_LIMIT_ENABLED=true
AGENT_RATE_LIMIT_REQUESTS=60
AGENT_RATE_LIMIT_WINDOW_SECONDS=60

# Default local mode: heuristic.
# Switch to upstream_openai_compatible only after filling MODEL / BASE_URL / API_KEY.
AGENT_TUTOR_BACKEND=heuristic
AGENT_TUTOR_MODEL=
AGENT_TUTOR_BASE_URL=
AGENT_TUTOR_API_KEY=
AGENT_TUTOR_TIMEOUT_SECONDS=60.0

# Default local mode: heuristic.
# Switch to openai_compatible only after filling MODEL / BASE_URL / API_KEY.
AGENT_UNDERSTANDING_BACKEND=heuristic
AGENT_UNDERSTANDING_MODEL=
AGENT_UNDERSTANDING_BASE_URL=
AGENT_UNDERSTANDING_API_KEY=
AGENT_UNDERSTANDING_TIMEOUT_SECONDS=60.0
